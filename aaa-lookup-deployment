apiVersion: apps/v1
kind: Deployment
metadata:
  name: aaa-lookup
spec:
  replicas: 1
  selector:
    matchLabels:
      app: aaa-lookup
  template:
    metadata:
      labels:
        app: aaa-lookup
    spec:
      containers:
        - name: aaa-lookup
          image: aaa-lookup:dev
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 8081
            - name: metrics
              containerPort: 9090
---
apiVersion: v1
kind: Service
metadata:
  name: aaa-lookup
spec:
  selector:
    app: aaa-lookup
  type: ClusterIP
  ports:
    - name: http
      port: 8081
      targetPort: 8081
    - name: metrics
      port: 9090
      targetPort: 9090
