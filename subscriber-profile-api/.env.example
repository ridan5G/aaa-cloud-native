# ── subscriber-profile-api environment configuration ──────────────────────────
# Copy this file to .env and fill in values for your environment.
# Local dev defaults are shown; all are overridable via environment variables.

# ── Database ──────────────────────────────────────────────────────────────────
# Full PostgreSQL URL. Overrides individual DB_* vars if set.
# In production, inject this from a Kubernetes Secret.
PRIMARY_URL=postgresql://aaa_app:devpassword@localhost:5432/aaa

# ── HTTP server ───────────────────────────────────────────────────────────────
# HTTP_PORT=8080
# METRICS_PORT=9091

# ── JWT authentication ────────────────────────────────────────────────────────
# Set to "true" only in local dev (bypasses signature check).
# JWT_SKIP_VERIFY=false
# JWT_PUBLIC_KEY=          # RS256 public key PEM (required when JWT_SKIP_VERIFY=false)
# JWT_ALGORITHM=RS256

# ── Bulk job worker settings ──────────────────────────────────────────────────
# BULK_WORKER_THREADS=4
# BULK_BATCH_SIZE=1000
