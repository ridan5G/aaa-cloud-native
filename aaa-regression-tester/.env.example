# ── aaa-regression-tester environment configuration ───────────────────────────
# Copy this file to .env and fill in values for your environment.
# Local dev defaults (localhost) are shown as comments.

# ── Image registry ────────────────────────────────────────────────────────────
# REGISTRY=k3d-aaa-registry.localhost:5111
# TAG=dev

# ── Database ──────────────────────────────────────────────────────────────────
# DB_NAME=aaa
# DB_USER=aaa_app
DB_PASSWORD=            # required — no default for non-local envs
# DB_HOST=localhost     # used by host-side tools (psql, migrations)
# DB_PORT=5432

# ── Service HTTP ports ────────────────────────────────────────────────────────
# PROVISION_HTTP_PORT=8080
# PROVISION_METRICS_PORT=9091
# LOOKUP_HTTP_PORT=8081
# LOOKUP_METRICS_PORT=9090

# ── Test client URLs (override for remote / pre-prod envs) ───────────────────
# PROVISION_URL=http://localhost:8080/v1
# LOOKUP_URL=http://localhost:8081/v1

# ── JWT token used by test client ─────────────────────────────────────────────
# TEST_JWT=dev-skip-verify   # in prod: use a signed token or service account

# ── RADIUS server ─────────────────────────────────────────────────────────────
# RADIUS_HOST=localhost
# RADIUS_PORT=1812
RADIUS_SECRET=          # required — must match the RADIUS_SECRET in aaa-radius-server
# RADIUS_WORKER_THREADS=8

# ── Prometheus Pushgateway ─────────────────────────────────────────────────────
# PUSHGATEWAY_PORT=9091
# PUSHGATEWAY_URL=http://localhost:9091
